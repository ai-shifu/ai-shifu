data: {"type": "element", "event_type": "element", "content": {"event_type": "element", "element_bid": "999a70226fc24d3288ea3fe3fe07c6de", "generated_block_bid": "d85fe35c500846d7a6edfe42fbc8179e", "element_index": 1, "role": "teacher", "element_type": "text", "element_type_code": 212, "is_renderable": false, "is_new": false, "is_marker": false, "sequence_number": 76, "is_speakable": true, "audio_url": "", "audio_segments": [], "is_navigable": 1, "is_final": false, "content": "你有没有过这种体验？刚接触 ChatGPT 或者咱们国内常用的那些大模型聊天机器人时，简直惊为天人——“**它怎么啥都知道？**” 从写代码到写情书，从解数学题到编科幻小说，感觉它脑子里装下了整个互联网。\n\n但用着用着，火气就上来了。让它算个“50 人的会议，每桌坐 8 人，需要多少桌”，它可能给你算出个 6.25 桌，还一本正经地建议你“可以考虑准备 7 桌，其中一桌只坐 2 人”。**前一秒是博古通今的智者，后一秒就成了气死人的“人工智障”**。这种冰火两重天的体验，是不是让你又爱又恨？\n", "payload": {"audio": null, "previous_visuals": []}, "run_session_bid": "4bca121a64fa484dbd019e8d78dd1ca5", "run_event_seq": 119, "change_type": "render", "target_element_bid": "999a70226fc24d3288ea3fe3fe07c6de"}, "generated_block_bid": "d85fe35c500846d7a6edfe42fbc8179e", "run_session_bid": "4bca121a64fa484dbd019e8d78dd1ca5", "run_event_seq": 119}

data: {"type": "element", "event_type": "element", "content": {"event_type": "element", "element_bid": "999a70226fc24d3288ea3fe3fe07c6de", "generated_block_bid": "d85fe35c500846d7a6edfe42fbc8179e", "element_index": 1, "role": "teacher", "element_type": "text", "element_type_code": 212, "is_renderable": false, "is_new": false, "is_marker": false, "sequence_number": 77, "is_speakable": true, "audio_url": "", "audio_segments": [], "is_navigable": 1, "is_final": false, "content": "你有没有过这种体验？刚接触 ChatGPT 或者咱们国内常用的那些大模型聊天机器人时，简直惊为天人——“**它怎么啥都知道？**” 从写代码到写情书，从解数学题到编科幻小说，感觉它脑子里装下了整个互联网。\n\n但用着用着，火气就上来了。让它算个“50 人的会议，每桌坐 8 人，需要多少桌”，它可能给你算出个 6.25 桌，还一本正经地建议你“可以考虑准备 7 桌，其中一桌只坐 2 人”。**前一秒是博古通今的智者，后一秒就成了气死人的“人工智障”**。这种冰火两重天的体验，是不是让你又爱又恨？\n\n", "payload": {"audio": null, "previous_visuals": []}, "run_session_bid": "4bca121a64fa484dbd019e8d78dd1ca5", "run_event_seq": 120, "change_type": "render", "target_element_bid": "999a70226fc24d3288ea3fe3fe07c6de"}, "generated_block_bid": "d85fe35c500846d7a6edfe42fbc8179e", "run_session_bid": "4bca121a64fa484dbd019e8d78dd1ca5", "run_event_seq": 120}

