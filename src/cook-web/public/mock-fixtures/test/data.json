data: {"type": "element", "event_type": "element", "content": {"event_type": "element", "element_bid": "24dcac27ce6e41388aec5d5b7c094e5d", "generated_block_bid": "34c71905f1f74548a9a603d39f3d6247", "element_index": 0, "role": "teacher", "element_type": "text", "element_type_code": 213, "is_renderable": false, "is_new": true, "is_marker": false, "sequence_number": 48, "is_speakable": true, "audio_url": "https://res.ai-shifu.cn/tts-audio/b4b47f9991684c10ab2db52eab03c990.mp3", "audio_segments": [{"position": 0, "segment_index": 0, "audio_data": "", "duration_ms": 4168, "is_final": true, "subtitle_cues": [{"text": "你好！", "start_ms": 0, "end_ms": 771, "segment_index": 0, "position": 0}, {"text": "终于见面了，特别开心能和你开启这趟学习之旅。", "start_ms": 971, "end_ms": 4168, "segment_index": 0, "position": 0}]}], "is_navigable": 1, "is_final": true, "content": "你好！终于见面了，特别开心能和你开启这趟学习之旅。\n", "payload": {"audio": {"position": 0, "audio_url": "https://res.ai-shifu.cn/tts-audio/b4b47f9991684c10ab2db52eab03c990.mp3", "audio_bid": "b4b47f9991684c10ab2db52eab03c990", "duration_ms": 4168, "subtitle_cues": [{"text": "你好！", "start_ms": 0, "end_ms": 771, "segment_index": 0, "position": 0}, {"text": "终于见面了，特别开心能和你开启这趟学习之旅。", "start_ms": 971, "end_ms": 4168, "segment_index": 0, "position": 0}]}, "previous_visuals": []}, "run_session_bid": "edf5fc0fddc745789dcb82de24465fc9", "run_event_seq": 152, "change_type": "render"}, "generated_block_bid": "34c71905f1f74548a9a603d39f3d6247", "run_session_bid": "edf5fc0fddc745789dcb82de24465fc9", "run_event_seq": 152}

