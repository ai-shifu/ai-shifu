data: {"type": "element", "event_type": "element", "content": {"event_type": "element", "element_bid": "44da731d67ac4a4bad4c5c207abfe9e5", "generated_block_bid": "34c71905f1f74548a9a603d39f3d6247", "element_index": 2, "role": "teacher", "element_type": "text", "element_type_code": 213, "is_renderable": false, "is_new": true, "is_marker": false, "sequence_number": 22, "is_speakable": true, "audio_url": "", "audio_segments": [], "is_navigable": 1, "is_final": false, "content": "\n我是孙志岗，AI 师傅的创始人。曾经在哈尔滨工业大学当了十几年计算机专业副教授，后来在网易、得到 App 和一家独角兽级创业公司做过中高管，负责过产品、技术和业务。我的工作领域一直是互联网、人工智能和教育的结合，算下来已经有 **20 多年** 了。\n", "payload": {"audio": null, "previous_visuals": []}, "run_session_bid": "edf5fc0fddc745789dcb82de24465fc9", "run_event_seq": 42, "change_type": "render"}, "generated_block_bid": "34c71905f1f74548a9a603d39f3d6247", "run_session_bid": "edf5fc0fddc745789dcb82de24465fc9", "run_event_seq": 42}

